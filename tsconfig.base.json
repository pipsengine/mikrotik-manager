{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@mikroktic-manager/shared": ["packages/shared/src/index.ts"],
      "@mikroktic-manager/security-kit": ["packages/security-kit/src/index.ts"],
      "@mikroktic-manager/database": ["packages/database/src/index.ts"],
      "@mikroktic-manager/ui": ["packages/ui/src/index.ts"]
    }
  }
}
